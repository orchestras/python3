#!/usr/bin/env bash
# mise description="Sync src/python_template/version.py from pyproject.toml"
set -euo pipefail

version=$(python -c "
import tomllib, pathlib
data = tomllib.loads(pathlib.Path('pyproject.toml').read_text())
print(data['project']['version'])
")

cat > src/python_template/version.py << PYEOF
# This file is auto-generated by \`mise run build\`.
# Do not edit manually — run \`mise run version:sync\` to regenerate.
__version__ = "${version}"
PYEOF

echo "✓ version.py synced to ${version}"
