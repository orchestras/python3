#!/usr/bin/env bash
#MISE description="Delete all local tags only if no tags exist on the remote"
set -euo pipefail

git fetch --tags origin

remote_count=$(git ls-remote --tags origin 'refs/tags/v*' 2>/dev/null | grep -v '\^{}' | wc -l | tr -d ' ')

if [ "$remote_count" -eq 0 ]; then
  local_count=$(git tag -l 'v*' | wc -l | tr -d ' ')
  if [ "$local_count" -gt 0 ]; then
    git tag -l 'v*' | xargs git tag -d
    echo "✓ Deleted ${local_count} local tags"
  else
    echo "No local or remote tags. Nothing to do."
  fi
else
  echo "Remote has ${remote_count} tags — keeping local tags intact."
fi
