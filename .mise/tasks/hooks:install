#!/usr/bin/env bash
# mise description="Install (symlink) the project git hooks into .git/hooks"
set -euo pipefail

HOOKS_DIR="config/githooks/hooks"
GIT_HOOKS_DIR=".git/hooks"

if [ ! -d "${HOOKS_DIR}" ]; then
  echo "No hooks found in ${HOOKS_DIR}. Run 'mise run hooks:sync' first."
  exit 1
fi

# Prefer core.hooksPath (already set by git:config)
# But also symlink for fallback compatibility
git config --local core.hooksPath "${HOOKS_DIR}"
echo "✓ core.hooksPath set to ${HOOKS_DIR}"

# List installed hooks
echo ""
echo "Installed hooks:"
for hook in "${HOOKS_DIR}"/*; do
  [ -f "$hook" ] && echo "  - $(basename "$hook")"
done
