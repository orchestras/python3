#!/usr/bin/env bash
# mise description="Display current gh CLI auth status and token scope"
set -euo pipefail

if ! gh auth status 2>&1; then
  echo ""
  echo "Not authenticated. Run: gh auth login"
  exit 1
fi

echo ""
echo "Token is managed by gh CLI."
echo "Use 'gh api ...' for API calls — no local token storage needed."
