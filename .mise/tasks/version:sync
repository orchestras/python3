#!/usr/bin/env bash
# mise description="Fetch remote tags and sync pyproject.toml + version.py to latest"
set -euo pipefail

echo "Fetching tags from origin..."
git fetch --tags origin

tag=$(git tag -l 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -v '+' | head -n 1)
if [ -z "$tag" ]; then
  echo "No semver tags found — defaulting to v0.1.0"
  tag="v0.1.0"
fi

# Strip leading 'v' for pyproject.toml
ver="${tag#v}"

# Update pyproject.toml version
python -c "
import re, pathlib, sys
p = pathlib.Path('pyproject.toml')
content = p.read_text()
updated = re.sub(r'^version = \"[^\"]+\"', 'version = \"${ver}\"', content, count=1, flags=re.MULTILINE)
if content == updated:
    print('Version already ${ver} — no change', file=sys.stderr)
else:
    p.write_text(updated)
"

mise run build

echo "✓ Version synced to ${tag} (pyproject.toml: ${ver})"
