#!/usr/bin/env bash
# mise description="Trigger a GitHub Advanced Security (CodeQL) scan via workflow dispatch"
set -euo pipefail

if ! gh auth status &>/dev/null; then
  echo "ERROR: gh CLI not authenticated. Run: gh auth login"
  exit 1
fi

REPO=$(gh repo view --json nameWithOwner -q '.nameWithOwner')
echo "Triggering GHAS scan for ${REPO}..."

gh workflow run ghas-scan.yml -R "${REPO}" 2>/dev/null || {
  echo "Workflow 'ghas-scan.yml' not found or dispatch failed."
  echo "Check: Actions → GHAS Security Scan → Run workflow"
  exit 1
}

echo "✓ GHAS scan dispatched. Check: gh run list --workflow=ghas-scan.yml"
