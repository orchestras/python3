#!/usr/bin/env bash
# mise description="Scan the repo for leaked secrets with trufflehog or gitleaks"
set -euo pipefail

if command -v trufflehog &>/dev/null; then
  echo "Running trufflehog..."
  trufflehog filesystem . --only-verified --exclude-paths .hogignore
elif command -v gitleaks &>/dev/null; then
  echo "Running gitleaks..."
  gitleaks detect --source . --no-git
else
  echo "No secret scanner found."
  echo "Install one of:"
  echo "  - trufflehog: https://github.com/trufflesecurity/trufflehog"
  echo "  - gitleaks:   https://github.com/gitleaks/gitleaks"
  exit 1
fi
