#!/usr/bin/env bash
# mise description="Sync git hooks from orchestras/git-hooks at the version in mise.toml [env.GITHOOKS_VERSION]"
set -euo pipefail

HOOKS_REPO="${GITHOOKS_REPO:-orchestras/git-hooks}"
HOOKS_VERSION="${GITHOOKS_VERSION:-main}"
HOOKS_DIR="config/githooks/hooks"
CACHE_DIR=".mise/.githooks-cache"

echo "Syncing git hooks from ${HOOKS_REPO}@${HOOKS_VERSION}..."

# Download via gh CLI or curl
if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
  echo "Using gh CLI..."
  mkdir -p "${CACHE_DIR}"
  gh api "repos/${HOOKS_REPO}/tarball/${HOOKS_VERSION}" \
    --header "Accept: application/vnd.github+json" \
    > "${CACHE_DIR}/hooks.tar.gz" 2>/dev/null || {
    echo "⚠  gh API download failed, trying raw tarball..."
    curl -sSfL "https://github.com/${HOOKS_REPO}/archive/${HOOKS_VERSION}.tar.gz" \
      -o "${CACHE_DIR}/hooks.tar.gz"
  }
else
  echo "Using curl (gh CLI not authenticated)..."
  mkdir -p "${CACHE_DIR}"
  curl -sSfL "https://github.com/${HOOKS_REPO}/archive/${HOOKS_VERSION}.tar.gz" \
    -o "${CACHE_DIR}/hooks.tar.gz"
fi

# Extract
rm -rf "${CACHE_DIR}/extracted"
mkdir -p "${CACHE_DIR}/extracted"
tar -xzf "${CACHE_DIR}/hooks.tar.gz" -C "${CACHE_DIR}/extracted" --strip-components=1

# Copy hooks if they exist in the expected location
if [ -d "${CACHE_DIR}/extracted/hooks" ]; then
  mkdir -p "${HOOKS_DIR}"
  cp -r "${CACHE_DIR}/extracted/hooks/." "${HOOKS_DIR}/"
  chmod +x "${HOOKS_DIR}"/* 2>/dev/null || true
  echo "✓ Hooks synced from ${HOOKS_REPO}@${HOOKS_VERSION} → ${HOOKS_DIR}/"
elif [ -d "${CACHE_DIR}/extracted" ]; then
  echo "⚠  No 'hooks/' directory found in repo — syncing all files..."
  mkdir -p "${HOOKS_DIR}"
  find "${CACHE_DIR}/extracted" -maxdepth 1 -type f -not -name "*.md" \
    -exec cp {} "${HOOKS_DIR}/" \;
  chmod +x "${HOOKS_DIR}"/* 2>/dev/null || true
  echo "✓ Hooks synced → ${HOOKS_DIR}/"
else
  echo "ERROR: Failed to extract hooks archive."
  exit 1
fi

# Update the recorded version in mise.toml if needed
echo "  GITHOOKS_VERSION = ${HOOKS_VERSION}"
echo ""
echo "To update hooks later, change GITHOOKS_VERSION in mise.toml and re-run:"
echo "  mise run hooks:sync"
