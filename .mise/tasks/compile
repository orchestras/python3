#!/usr/bin/env bash
# mise description="Compile cross-platform binaries with PyInstaller to ./bin/"
set -euo pipefail

if ! python -c "import PyInstaller" &>/dev/null; then
  echo "PyInstaller not installed. Run: uv sync --extra dev"
  exit 1
fi

version=$(python -c "
import tomllib, pathlib
data = tomllib.loads(pathlib.Path('pyproject.toml').read_text())
print(data['project']['version'])
")

name=$(python -c "
import tomllib, pathlib
data = tomllib.loads(pathlib.Path('pyproject.toml').read_text())
print(data['project']['name'])
")

mkdir -p bin

echo "Building standalone binary for $(uname -s)/$(uname -m)..."

pyinstaller \
  --onefile \
  --clean \
  --name "${name}" \
  --distpath bin \
  --workpath build/pyinstaller \
  --specpath build \
  src/python_template/__main__.py

echo ""
echo "✓ Binary compiled: bin/${name}"
echo "  Version: ${version}"
echo "  Platform: $(uname -s)-$(uname -m)"
echo ""
echo "Note: For cross-platform builds, use the CI release workflow."
echo "  Each platform must build natively (Linux → Linux, macOS → macOS, etc.)"
