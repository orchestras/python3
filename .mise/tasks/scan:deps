#!/usr/bin/env bash
# mise description="Audit Python dependencies for known vulnerabilities (pip-audit)"
set -euo pipefail

if command -v pip-audit &>/dev/null; then
  echo "Running pip-audit..."
  pip-audit
elif uv tool list 2>/dev/null | grep -q pip-audit; then
  echo "Running pip-audit via uv tool..."
  uv tool run pip-audit
else
  echo "pip-audit not found. Installing..."
  uv tool install pip-audit
  uv tool run pip-audit
fi
