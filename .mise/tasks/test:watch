#!/usr/bin/env bash
# mise description="Run tests in watch mode (requires pytest-watch)"
set -euo pipefail
if ! python -m pytest --co -q &>/dev/null; then
  echo "No tests found or pytest not installed."
  exit 1
fi
if command -v ptw &>/dev/null; then
  ptw -- tests/
else
  echo "Install pytest-watch: uv add --dev pytest-watch"
  echo "Falling back to single run..."
  python -m pytest tests/
fi
