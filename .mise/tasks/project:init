#!/usr/bin/env bash
# mise description="Full project init: install deps, git config, sync tags, init version, bootstrap hooks"
set -euo pipefail

echo "=== Project Initialisation ==="
echo ""

echo "1/6 Installing dependencies..."
mise run install

echo ""
echo "2/6 Configuring local git..."
mise run git:config || echo "⚠  git config skipped (GPG key may not be set up)"

echo ""
echo "3/6 Syncing tags from remote..."
mise run tag:sync || echo "⚠  tag sync skipped (no remote)"

echo ""
echo "4/6 Initialising version..."
mise run version:init || echo "⚠  version init skipped"

echo ""
echo "5/6 Syncing version..."
mise run version:sync || echo "⚠  version sync skipped"

echo ""
echo "6/6 Installing shell completions..."
mise run completions || true

echo ""
echo "✓ Project initialised."
echo "  Run 'mise tasks' for all available tasks."
