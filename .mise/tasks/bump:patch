#!/usr/bin/env bash
# mise description="Bump patch version (e.g. 0.1.5 → 0.1.6), update pyproject.toml + version.py, create git tag"
set -euo pipefail

SCRIPTS_DIR="$(git rev-parse --show-toplevel)/scripts"

git fetch --tags origin

latest=$(git tag -l 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -v '+' | head -n 1)
[ -z "$latest" ] && latest="v0.0.0"

ver="${latest#v}"
new_ver=$("${SCRIPTS_DIR}/semver.sh" bump patch "$ver")
new_tag="v${new_ver}"

# Update pyproject.toml
python -c "
import re, pathlib
p = pathlib.Path('pyproject.toml')
content = p.read_text()
updated = re.sub(r'^version = \"[^\"]+\"', 'version = \"${new_ver}\"', content, count=1, flags=re.MULTILINE)
p.write_text(updated)
print('Updated pyproject.toml to ${new_ver}')
"

# Regenerate version.py
mise run build

# Commit the version bump
git add pyproject.toml src/python_template/version.py
git commit -m "chore: bump version ${latest} → ${new_tag}"

# Create annotated tag (not pushed)
if git tag -l | grep -qx "${new_tag}"; then
  echo "Tag ${new_tag} already exists locally."
else
  git tag -a "${new_tag}" -m "${new_tag}"
fi

echo "✓ Bumped ${latest} → ${new_tag} (committed + tagged, NOT pushed)"
echo "  Run 'mise run tag:push' to push the tag and trigger release."
